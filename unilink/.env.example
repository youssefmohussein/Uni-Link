# ─── ENVIRONMENT VARIABLE TEMPLATE ───────────────────────────────────────────
#
# FOR LOCAL DEV:
#   Copy this file to:  .env.development.local
#   Then run:           npm run dev
#
#   This file is ONLY loaded during `npm run dev`.
#   It is NOT loaded during `npm run build`, so localhost never gets
#   baked into the production bundle.
#
# FOR PRODUCTION (Linux server):
#   Do nothing — no env file needed on the server.
#   The frontend auto-detects the backend at:  <same-origin>/backend
#   e.g.  http://192.168.1.10/backend  or  https://your-domain.com/backend
#
# ─────────────────────────────────────────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:8000
